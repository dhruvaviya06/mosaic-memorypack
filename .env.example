# ==========================================================================
# Memory Mesh / RiskLore — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Stack: self-hosted Cognee (local LanceDB + Kuzu + SQLite) + Gemini free tier.
# ==========================================================================

# --- LLM (reasoning) ---------------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey
# cognee routes through litellm, so provider is "gemini" and models are prefixed "gemini/".
LLM_PROVIDER=gemini
# NOTE: on the free tier, gemini-2.0-flash / 2.5-pro return "limit: 0" (no free quota).
# gemini-2.5-flash and 2.5-flash-lite DO have free quota. Verified 2026-07-05.
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=your_google_ai_studio_key_here

# --- Embeddings (re-embedded LOCALLY on import — the model-agnostic claim) ----
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=your_google_ai_studio_key_here

# --- Cognee behavior tuning (see Phase 0 notes) ------------------------------
# Single-user local hackathon: turn OFF multi-tenant auth so calls don't need a login/user context.
ENABLE_BACKEND_ACCESS_CONTROL=false
# Deterministic demo: turn OFF session-memory caching so recall answers don't drift between runs.
CACHING=false
