# ==========================================================================
# Mosaic / Tessera — environment template
# Copy this file to `.env` and fill in a real LLM key. `.env` is gitignored.
# Stack: self-hosted Cognee (local LanceDB + Kuzu + SQLite) + LOCAL embeddings.
# ==========================================================================

# --- LLM (reasoning) ---------------------------------------------------------
# Pick ONE provider below and paste its key. cognee routes through litellm.
#
# Option A (free) — Google Gemini. Free key: https://aistudio.google.com/apikey
#   NOTE: free tier is per-project-per-day; gemini-2.5-flash works, 2.0-flash is limit:0.
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=your_llm_api_key_here
#
# Option B (free, higher limits) — Groq (OpenAI-compatible; use cognee's 'custom' provider):
#   LLM_PROVIDER=custom
#   LLM_MODEL=groq/llama-3.3-70b-versatile
#   LLM_API_KEY=your_groq_key           # free at console.groq.com
#
# Option C (paid, most reliable) — OpenAI:
#   LLM_PROVIDER=openai
#   LLM_MODEL=openai/gpt-4o-mini
#   LLM_API_KEY=your_openai_key

# --- Embeddings — LOCAL, no API key, no quota (this IS the "re-embeds locally" claim) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# --- Cognee behavior tuning --------------------------------------------------
# Single-user self-hosted: turn OFF multi-tenant auth so calls need no login/user context.
ENABLE_BACKEND_ACCESS_CONTROL=false
# Deterministic answers: turn OFF session-memory caching so recall doesn't drift between runs.
CACHING=false
