# --- Secrets: never commit real keys ---
.env

# --- Python virtual environment (thousands of library files, rebuildable) ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# --- Cognee local state (databases, logs, caches) ---
.cognee*
*.lancedb

# --- Debug graph visualizations (regenerable from the graph) ---
pack/*.html

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/

# --- Built pack artifacts (regenerable via export_pack.py) ---
pack/*.mempack
